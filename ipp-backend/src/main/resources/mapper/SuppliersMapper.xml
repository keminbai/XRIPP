<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xripp.backend.mapper.SuppliersMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.xripp.backend.entity.Suppliers">
        <id column="id" property="id" />
        <result column="supplier_no" property="supplierNo" />
        <result column="company_name" property="companyName" />
        <result column="partner_id" property="partnerId" />
        <result column="audit_status" property="auditStatus" />
        <result column="submit_time" property="submitTime" />
        <result column="created_at" property="createdAt" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, supplier_no, company_name, partner_id, audit_status, submit_time, created_at
    </sql>

</mapper>
